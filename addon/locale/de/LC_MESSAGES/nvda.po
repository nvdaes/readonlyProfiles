#. Translators: Message presented in input help mode.
#: addon\globalPlugins\readonlyProfiles.py:35
msgid "Saves the current configuration to the most recent profile"
msgstr "Speichert die aktuelle Konfiguration im aktuellen Profil"

#. Translators: Message presented when the user tries to save normal configuration.
#: addon\globalPlugins\readonlyProfiles.py:43
msgid "Normal configuration cannot be saved with this command"
msgstr "Die normale Konfiguration kann mit diesem Befehl nicht gespeichert werden"

#. Translators: Message presented when a profile is saved.
#: addon\globalPlugins\readonlyProfiles.py:47
#, python-brace-format
msgid "Saved profile: {profile}"
msgstr "Gespeichertes Profil: {profile}"

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: buildVars.py:21
msgid "Readonly Profiles"
msgstr "Schreibgeschützte Profile"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:24
msgid "Don't save profiles automatically. Press NVDA+shift+p to save the most recent profile."
msgstr "Profile nicht automatisch speichern. Drücken Sie NVDA+Umschalt+p, um das neueste Profil zu speichern."

